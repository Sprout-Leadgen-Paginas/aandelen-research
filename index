<style>
  :root{
    --navy:#0D1B2A;--navy-2:#142436;--blue:#1E3A8A;
    --bg:#F8FAFC;--white:#fff;--line:#E2E8F0;--line-2:#CBD5E1;
    --ink:#0F172A;--slate:#475569;--slate-soft:#64748B;
    --emerald:#10B981;--emerald-deep:#059669;
    --orange:#F97316;--orange-hi:#FF6B35;--orange-deep:#C2410C;
    --on-navy:rgba(255,255,255,.82);--on-navy-soft:rgba(255,255,255,.55);
    --maxw:1120px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{background:var(--bg);color:var(--ink);font-family:"Inter",system-ui,sans-serif;font-size:17px;line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
  ::selection{background:var(--emerald);color:#fff}
  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 26px}
  .mono{font-family:"JetBrains Mono",monospace}
  h1,h2,h3{font-family:"Plus Jakarta Sans",sans-serif;line-height:1.08;letter-spacing:-.02em;font-weight:800}
  .eyebrow{font-family:"JetBrains Mono",monospace;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--emerald)}
  a{color:inherit}

  .btn{appearance:none;border:none;cursor:pointer;font-family:"Plus Jakarta Sans",sans-serif;font-weight:700;font-size:17px;color:#fff;background:var(--orange);padding:16px 28px;border-radius:9px;white-space:nowrap;box-shadow:0 4px 0 var(--orange-deep),0 12px 28px -10px rgba(249,115,22,.6);transition:transform .16s ease,background .16s ease,box-shadow .16s ease}
  .btn:hover{background:var(--orange-hi);transform:translateY(-2px);box-shadow:0 6px 0 var(--orange-deep),0 18px 36px -12px rgba(255,107,53,.7)}
  .btn:active{transform:translateY(2px);box-shadow:0 1px 0 var(--orange-deep)}

  .capture{display:flex;gap:10px;flex-wrap:wrap;max-width:540px}
  .capture .field{flex:1 1 250px}
  .capture input[type=email]{width:100%;min-height:56px;border-radius:9px;font-family:"Inter",sans-serif;font-size:16px;padding:14px 16px;background:#fff;border:1.5px solid var(--line-2);color:var(--ink)}
  .capture input[type=email]::placeholder{color:#94A3B8}
  .capture input[type=email]:focus{outline:none;border-color:var(--emerald);box-shadow:0 0 0 3px rgba(16,185,129,.22)}
  .capture .btn{flex:0 0 auto}

  .ticks{display:flex;flex-wrap:wrap;gap:14px 24px;margin:0 0 24px}
  .tick{display:flex;align-items:center;gap:8px;font-size:14.5px;font-weight:600;color:var(--on-navy)}
  .tick svg{width:18px;height:18px;flex:none}
  .check circle{fill:var(--emerald)}.check path{stroke:#fff;stroke-width:2.4;fill:none;stroke-linecap:round;stroke-linejoin:round}

  .consent{font-family:"JetBrains Mono",monospace;font-size:11.5px;line-height:1.6;color:var(--on-navy-soft);margin-top:15px;max-width:46em}
  .consent a{color:inherit;text-decoration:underline;text-underline-offset:2px}
  .visually-hidden{position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap}
  *:focus-visible{outline:2px solid var(--orange);outline-offset:3px;border-radius:5px}

  /* TOPBAR */
  .topbar{background:var(--navy)}
  .topbar .wrap{display:flex;align-items:center;justify-content:space-between;height:62px}
  .logo{display:flex;align-items:center;gap:11px}
  .logo .mark{width:30px;height:30px;border-radius:7px;background:linear-gradient(150deg,var(--emerald),var(--emerald-deep));display:grid;place-items:center;flex:none}
  .logo .mark svg{width:17px;height:17px}.logo .mark path{stroke:#fff;stroke-width:2.4;fill:none;stroke-linecap:round;stroke-linejoin:round}
  .logo .name{font-family:"Plus Jakarta Sans",sans-serif;font-weight:800;font-size:18px;color:#fff}
  .topbar .meta{font-family:"JetBrains Mono",monospace;font-size:11.5px;letter-spacing:.06em;color:var(--on-navy-soft)}

  /* HERO */
  .hero{background:var(--navy);color:var(--on-navy);position:relative;overflow:hidden}
  .hero .chartbg{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;opacity:.5}
  .hero .glow{position:absolute;top:-22%;right:-8%;width:600px;height:600px;background:radial-gradient(circle,rgba(16,185,129,.14),transparent 60%);pointer-events:none}
  .hero .wrap{position:relative;z-index:1;display:grid;grid-template-columns:1.08fr .92fr;gap:54px;align-items:center;padding:60px 26px 70px}
  .hero .eyebrow{display:inline-block;margin-bottom:16px}
  .hero h1{color:#fff;font-size:clamp(34px,4.9vw,56px);margin-bottom:16px}
  .hero h1 span{color:var(--emerald)}
  .hero .lede{font-size:clamp(16.5px,1.4vw,19px);max-width:30em;margin-bottom:24px;color:var(--on-navy)}

  .report{background:#fff;color:var(--ink);border-radius:14px;box-shadow:0 40px 80px -34px rgba(0,0,0,.55);overflow:hidden}
  .report-top{background:var(--navy);color:#fff;padding:14px 22px;display:flex;justify-content:space-between;align-items:center}
  .report-top .t{font-family:"JetBrains Mono",monospace;font-size:11.5px;letter-spacing:.12em}
  .report-top .e{font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.08em;color:var(--emerald)}
  .report-body{padding:22px}
  .report .nm-row{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:6px}
  .blur-name{filter:blur(8px);user-select:none;pointer-events:none;font-family:"Plus Jakarta Sans",sans-serif;font-weight:800;font-size:24px;color:var(--ink)}
  .lock{display:inline-flex;align-items:center;gap:6px;font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.06em;background:var(--navy);color:var(--emerald);padding:6px 10px;border-radius:6px;white-space:nowrap}
  .lock svg{width:12px;height:12px}.lock path,.lock rect{stroke:var(--emerald);stroke-width:2.2;fill:none}
  .report .reveal-note{font-family:"JetBrains Mono",monospace;font-size:11px;color:var(--slate-soft);margin-bottom:18px}
  .report .grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--line);border:1px solid var(--line);border-radius:9px;overflow:hidden;margin-bottom:18px}
  .report .cell{background:#fff;padding:12px 14px}
  .report .cell .k{font-family:"JetBrains Mono",monospace;font-size:9.5px;letter-spacing:.08em;text-transform:uppercase;color:var(--slate-soft);margin-bottom:5px}
  .report .cell .v{font-family:"Plus Jakarta Sans",sans-serif;font-weight:700;font-size:17px}
  .report .cell .v.up{color:var(--emerald-deep)}
  .report .cell .v.r{filter:blur(7px);user-select:none}
  .report .th-lbl{font-family:"JetBrains Mono",monospace;font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--emerald-deep);margin-bottom:7px}
  .report .th p{font-size:13.5px;line-height:1.5;color:#334155;filter:blur(3.6px);user-select:none}

  /* BENEFITS-REGEL */
  .benefits{background:#fff;border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
  .benefits .wrap{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:14px 26px;padding:22px 26px}
  .benefits .lab{font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--slate-soft)}
  .chip{display:flex;align-items:center;gap:8px;font-weight:700;font-size:15px;color:var(--ink)}
  .chip .d{width:7px;height:7px;border-radius:50%;background:var(--emerald);flex:none}

  /* PARTNERS */
  .partners{background:var(--bg);padding:64px 0}
  .partners .head{text-align:center;max-width:620px;margin:0 auto 36px}
  .partners .head h2{font-size:clamp(24px,2.8vw,34px);margin-top:12px;color:var(--ink)}
  .pgrid{display:grid;grid-template-columns:1fr 1fr;gap:18px}
  .pcard{background:#fff;border:1px solid var(--line);border-radius:14px;padding:28px 30px;display:flex;gap:18px;align-items:flex-start;transition:transform .2s ease,box-shadow .2s ease}
  .pcard:hover{transform:translateY(-3px);box-shadow:0 20px 40px -26px rgba(13,27,42,.4)}
  .pcard .pm{width:52px;height:52px;border-radius:12px;display:grid;place-items:center;flex:none;font-family:"Plus Jakarta Sans",sans-serif;font-weight:800;font-size:18px;color:#fff;letter-spacing:.02em}
  .pm.vj{background:linear-gradient(150deg,var(--emerald),var(--emerald-deep))}
  .pm.bv{background:linear-gradient(150deg,var(--blue),var(--navy))}
  .pcard .pname{font-family:"Plus Jakarta Sans",sans-serif;font-weight:800;font-size:18px;color:var(--ink);margin-bottom:6px;display:flex;align-items:center;gap:9px}
  .pcard .ptag{font-family:"JetBrains Mono",monospace;font-size:9px;letter-spacing:.08em;text-transform:uppercase;color:var(--emerald-deep);background:rgba(16,185,129,.12);padding:3px 7px;border-radius:5px}
  .pcard p{color:var(--slate);font-size:15px;line-height:1.5}

  /* FINALE CTA */
  .final{background:var(--navy);color:#fff;position:relative;overflow:hidden}
  .final .glow{position:absolute;bottom:-45%;left:50%;transform:translateX(-50%);width:740px;height:540px;background:radial-gradient(circle,rgba(16,185,129,.16),transparent 60%);pointer-events:none}
  .final .wrap{position:relative;padding:70px 26px;text-align:center}
  .final h2{font-size:clamp(28px,3.6vw,44px);max-width:15em;margin:12px auto 12px}
  .final h2 span{color:var(--emerald)}
  .final .lede{color:var(--on-navy);max-width:32em;margin:0 auto 26px}
  .final .capture{margin:0 auto;justify-content:center}
  .final .consent{margin:16px auto 0;text-align:center}

  .success{display:none;max-width:540px;background:rgba(16,185,129,.12);border:1px solid var(--emerald);border-radius:11px;padding:22px 24px}
  .success.show{display:block;animation:rise .5s ease both}
  .success .h{font-family:"Plus Jakarta Sans",sans-serif;font-weight:800;font-size:21px;color:#fff;margin-bottom:5px;display:flex;align-items:center;gap:9px}
  .success .h svg{width:22px;height:22px}
  .success p{font-family:"JetBrains Mono",monospace;font-size:12.5px;color:var(--on-navy)}
  .hero .success{background:rgba(16,185,129,.1)}.hero .success .h{color:var(--ink)}.hero .success p{color:var(--slate)}
  .final .success{margin:0 auto}

  /* FOOTER */
  footer{background:#08111c;color:var(--on-navy-soft);padding:46px 0 54px;font-size:13.5px}
  footer .wrap{display:grid;gap:22px}
  footer .ftop{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:14px;padding-bottom:20px;border-bottom:1px solid rgba(255,255,255,.08)}
  footer .ftop .name{font-family:"Plus Jakarta Sans",sans-serif;font-weight:800;color:#fff;font-size:16px}
  footer .disc{font-family:"JetBrains Mono",monospace;font-size:11px;line-height:1.7;max-width:64em}
  footer .partner{color:var(--on-navy)}
  footer .legal{display:flex;gap:20px;flex-wrap:wrap;font-family:"JetBrains Mono",monospace;font-size:11px}
  footer .legal a{text-decoration:none;opacity:.8}footer .legal a:hover{opacity:1;color:#fff}

  /* STICKY MOBIEL */
  .sticky{position:fixed;left:0;right:0;bottom:0;z-index:20;background:var(--navy);border-top:1px solid rgba(255,255,255,.12);padding:12px 16px calc(12px + env(safe-area-inset-bottom));display:none;align-items:center;justify-content:space-between;gap:12px;transform:translateY(110%);transition:transform .3s ease;box-shadow:0 -8px 24px -12px rgba(0,0,0,.6)}
  .sticky.show{transform:translateY(0)}
  .sticky .lbl{color:#fff;font-weight:700;font-size:14px;font-family:"Plus Jakarta Sans",sans-serif;line-height:1.2}
  .sticky .lbl small{display:block;font-weight:400;font-size:11px;color:var(--on-navy-soft);font-family:"JetBrains Mono",monospace}
  .sticky .btn{padding:13px 20px;font-size:15px;box-shadow:0 3px 0 var(--orange-deep)}

  @keyframes rise{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
  .reveal{opacity:0;transform:translateY(18px)}
  .reveal.in{opacity:1;transform:translateY(0);transition:opacity .6s ease,transform .6s ease}

  @media(max-width:920px){
    .hero .wrap{grid-template-columns:1fr;gap:38px;padding:46px 26px 58px}
    .report{max-width:460px}
    .pgrid{grid-template-columns:1fr}
    .sticky{display:flex}
  }
  @media(max-width:540px){
    body{font-size:16px}.topbar .meta{display:none}
    .capture .btn{flex:1 1 100%}
    .benefits .wrap{justify-content:flex-start}
  }
  @media(prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important;scroll-behavior:auto!important}.reveal{opacity:1;transform:none}.sticky{transition:none}}
</style>
</head>
