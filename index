<div class="sticky" id="sticky" aria-hidden="true">
  <div class="lbl">Gratis maandanalyse<small>12 per jaar · geen kosten</small></div>
  <button class="btn" id="sticky-btn" type="button">Inschrijven</button>
</div>

<script>
  document.getElementById('yr').textContent = new Date().getFullYear();

  // UTM uit URL naar verborgen velden
  (function(){const p=new URLSearchParams(location.search);['utm_source','utm_medium','utm_campaign','utm_term','utm_content'].forEach(k=>{const v=p.get(k);if(!v)return;document.querySelectorAll('input[name="'+k+'"]').forEach(el=>el.value=v);});})();

  // Formulier — koppel hieronder je e-mailtool (Delivermail / Campaign Monitor / Mailchimp)
  function wire(formId,msgId,okId){
    const f=document.getElementById(formId),m=document.getElementById(msgId),ok=document.getElementById(okId),inp=f.querySelector('input[type=email]');
    f.addEventListener('submit',function(e){
      e.preventDefault();const v=inp.value.trim();
      if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)){m.textContent='Vul een geldig e-mailadres in om de gratis analyse te ontvangen.';m.style.color='#FF6B35';inp.focus();return;}
      // === HIER je e-mailtool koppelen ===
      // fetch('JOUW_ESP_ENDPOINT',{method:'POST',body:new FormData(f)});
      // ===================================
      f.style.display='none';m.style.display='none';ok.classList.add('show');
    });
  }
  wire('form-hero','msg-hero','ok-hero');
  wire('form-final','msg-final','ok-final');

  // Sticky mobiele CTA
  (function(){
    const bar=document.getElementById('sticky');
    document.getElementById('sticky-btn').addEventListener('click',function(){const i=document.getElementById('email-hero');i.scrollIntoView({behavior:'smooth',block:'center'});setTimeout(()=>i.focus(),420);});
    const io=new IntersectionObserver(es=>{es.forEach(en=>{bar.classList.toggle('show',!en.isIntersecting);});},{threshold:0});
    io.observe(document.querySelector('.hero'));
  })();

  // Reveal
  const io2=new IntersectionObserver(es=>{es.forEach(en=>{if(en.isIntersecting){en.target.classList.add('in');io2.unobserve(en.target);}})},{threshold:.12});
  document.querySelectorAll('.reveal').forEach((el,i)=>{el.style.transitionDelay=Math.min(i*35,210)+'ms';io2.observe(el);});
</script>
</body>
</html>
